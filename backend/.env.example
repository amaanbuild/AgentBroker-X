# Copy to .env for local development.
# Railway injects DATABASE_URL automatically when a Postgres plugin is attached.

APP_ENV=development

# Local default uses SQLite (zero setup). For Postgres, e.g.:
# DATABASE_URL=postgresql://user:pass@localhost:5432/agentbroker
DATABASE_URL=sqlite:///./agentbroker.db

TASK_TIMEOUT_SECONDS=120
HEARTBEAT_GRACE_SECONDS=45
PLATFORM_FEE_BPS=250
DEFAULT_STARTING_BALANCE=1000

CORS_ORIGINS=*
